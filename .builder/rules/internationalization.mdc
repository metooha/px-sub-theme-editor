## Common Patterns

### Page header

```tsx
const { t } = useTranslation('pages');

<h1>{t('myPage.title')}</h1>
<p>{t('myPage.description')}</p>
```

### Table column headers

```tsx
const { t } = useTranslation('pages');

<DataTableHeader>{t('myTable.colName')}</DataTableHeader>
<DataTableHeader>{t('myTable.colStatus')}</DataTableHeader>
```

### Status values with a lookup map

```tsx
const STATUS_KEYS: Record<string, string> = {
  Live: 'myFeature.statusLive',
  Paused: 'myFeature.statusPaused',
};

<Tag>{t(STATUS_KEYS[item.status])}</Tag>
```

### Dynamically mapped categories

```tsx
const CATEGORY_KEYS: Record<string, string> = {
  electronics: 'catalog.catElectronics',
  clothing: 'catalog.catClothing',
};

categories.map(cat => (
  <span key={cat}>{t(CATEGORY_KEYS[cat] ?? cat)}</span>
))
```

### Aria-labels with context

```jsonc
// en/pages.json
{
  "dataTable": {
    "actionsFor": "Actions for {{name}}"
  }
}
```

```tsx
<IconButton aria-label={t('dataTable.actionsFor', { name: item.name })}>
  <MoreHorizontal />
</IconButton>
```

